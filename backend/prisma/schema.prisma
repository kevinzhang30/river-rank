generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  elo         Int      @default(1000)
  gamesPlayed Int      @default(0)
  wins        Int      @default(0)
  losses      Int      @default(0)
  createdAt   DateTime @default(now())

  matchesAsP1 Match[] @relation("MatchP1")
  matchesAsP2 Match[] @relation("MatchP2")
}

model Match {
  id        String    @id @default(uuid())
  p1Id      String
  p2Id      String
  mode      String
  winnerId  String?
  createdAt DateTime  @default(now())
  endedAt   DateTime?

  p1 User @relation("MatchP1", fields: [p1Id], references: [id])
  p2 User @relation("MatchP2", fields: [p2Id], references: [id])
}

model Tournament {
  id        String    @id @default(uuid())
  hostId    String
  joinCode  String    @unique
  size      Int
  status    String    @default("lobby")
  winnerId  String?
  createdAt DateTime  @default(now())
  startedAt DateTime?
  endedAt   DateTime?
}

model TournamentParticipant {
  tournamentId String
  userId       String
  seed         Int?
  joinedAt     DateTime @default(now())
  @@id([tournamentId, userId])
}

model TournamentMatch {
  id           String   @id @default(uuid())
  tournamentId String
  round        Int
  position     Int
  p1Id         String?
  p2Id         String?
  winnerId     String?
  matchId      String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  @@unique([tournamentId, round, position])
}
